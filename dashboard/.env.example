# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=quirkly

# JWT Secret (Generate with: openssl rand -hex 64)
JWT_SECRET=your-super-secret-jwt-key-here-min-32-characters

# AI Provider Configuration
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
XAI_API_KEY=your-xai-api-key-here

# Ollama Configuration (Alternative to cloud providers)
# Coolify / Docker: Ollama must be reachable on the **internal** network (same stack). Use the service hostname:
# OLLAMA_INTERNAL_BASE_URL=http://ollama:11434
# Local dev (Ollama on your machine, app not in Docker): localhost is fine.
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_INTERNAL_BASE_URL=http://ollama:11434
# Optional extra origins to try (comma-separated), same internal network or host-only setups:
# OLLAMA_TRY_GATEWAYS=
# OLLAMA_PORT=11434
# OLLAMA_FETCH_IPV4=1
# Only if Ollama listens on the host (not recommended for Coolify): OLLAMA_DISCOVER_HOST_GATEWAY=1 or OLLAMA_AUTO_BRIDGE_FALLBACK=1
OLLAMA_MODEL=llama2
OLLAMA_API_KEY=your-ollama-api-key-here # Optional, only if Ollama requires auth

# Cloud Ollama (ollama.com API)
OLLAMA_USE_CLOUD=false # Set to 'true' to use ollama.com API instead of local
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-api-key-here # Required when OLLAMA_USE_CLOUD=true
# OLLAMA_CLOUD_THINK=low|medium|high|false — gpt-oss ignores false; app defaults gpt-oss to low. false turns off thinking on models that support it.
# OLLAMA_CLOUD_MIN_NUM_PREDICT=512 — minimum num_predict on cloud (thinking models need headroom or message.content stays empty)

# Reply Generation - RAG Feature (Experimental)
# Set to 'true' to enable RAG (Retrieval Augmented Generation) for replies
# This retrieves relevant knowledge from the knowledge base to make replies more contextual
# Disable if replies become too bookish or if you want faster response times
REPLY_USE_RAG=false # Options: true | false

# Stripe Configuration (Optional - for payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# App Configuration
NEXT_PUBLIC_APP_URL=https://quirkly.technioz.com
NODE_ENV=production

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
