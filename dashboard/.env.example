# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=quirkly

# JWT Secret (Generate with: openssl rand -hex 64)
JWT_SECRET=your-super-secret-jwt-key-here-min-32-characters

# AI Provider Configuration
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
XAI_API_KEY=your-xai-api-key-here

# Ollama Configuration (Alternative to cloud providers)
# Local dev: localhost is fine.
# Docker/Coolify: curl http://localhost:11434 on the *host* works, but inside the app container localhost is NOT the host.
# Fix: OLLAMA_DISCOVER_HOST_GATEWAY=1 (Linux) adds http://<default-gateway>:OLLAMA_PORT (from /proc/net/route → usually host)
# Or: OLLAMA_AUTO_BRIDGE_FALLBACK=1 with localhost in OLLAMA_BASE_URL (adds gateway discovery + 172.17/172.18/host.docker.internal)
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_PORT=11434
# OLLAMA_DISCOVER_HOST_GATEWAY=1
# OLLAMA_AUTO_BRIDGE_FALLBACK=1
# OLLAMA_INTERNAL_BASE_URL=http://ollama:11434
# OLLAMA_TRY_GATEWAYS=http://172.17.0.1:11434
# OLLAMA_FETCH_IPV4=1
OLLAMA_MODEL=llama2
OLLAMA_API_KEY=your-ollama-api-key-here # Optional, only if Ollama requires auth

# Stripe Configuration (Optional - for payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# App Configuration
NEXT_PUBLIC_APP_URL=https://quirkly.technioz.com
NODE_ENV=production

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
